// Read environments dynamically from environments.json
def getEnvironments() {
    def configFile = readFile('src/config/environments.json')
    def config = new groovy.json.JsonSlurper().parseText(configFile)
    return config.keySet().findAll { it != '_defaults' }.join('\n')
}

pipeline {
    agent any
    
    parameters {
        // ENV choices are loaded dynamically from environments.json
        // First build uses fallback, subsequent builds use dynamic list
        choice(name: 'ENV', choices: ['qa', 'dev', 'stage', 'uat', 'prod'], description: 'Target environment (from environments.json)')
        choice(name: 'BROWSER', choices: ['chromium', 'firefox', 'webkit'], description: 'Browser to run tests')
        booleanParam(name: 'HEADLESS', defaultValue: true, description: 'Run in headless mode')
        string(name: 'PARALLEL', defaultValue: '0', description: 'Number of parallel workers (0 = sequential)')
        string(name: 'RETRY', defaultValue: '1', description: 'Number of retry attempts for failed tests')
        string(name: 'FEATURE_FILE', defaultValue: '', description: 'Specific feature file to run (leave empty for all)')
        string(name: 'TAGS', defaultValue: '', description: 'Cucumber tags to run (e.g., @smoke, @regression, "not @skip")')
    }
    
    environment {
        ENV = "${params.ENV}"
        BROWSER = "${params.BROWSER}"
        HEADLESS = "${params.HEADLESS}"
        PARALLEL = "${params.PARALLEL}"
        RETRY = "${params.RETRY}"
        TAGS = "${params.TAGS}"
        NODE_OPTIONS = '--max-old-space-size=4096'
        TIMESTAMP = new Date().format("yyyy-MM-dd'T'HH-mm-ss", TimeZone.getTimeZone('UTC'))
    }
    
    options {
        timeout(time: 60, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '20', artifactNumToKeepStr: '10'))
        timestamps()
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Setup') {
            steps {
                script {
                    // Validate selected environment exists in environments.json
                    def configFile = readFile('src/config/environments.json')
                    def config = new groovy.json.JsonSlurper().parseText(configFile)
                    def availableEnvs = config.keySet().findAll { it != '_defaults' }
                    
                    if (!availableEnvs.contains(params.ENV)) {
                        error "Environment '${params.ENV}' not found in environments.json. Available: ${availableEnvs.join(', ')}"
                    }
                    
                    echo "Available environments: ${availableEnvs.join(', ')}"
                    echo "Selected environment: ${params.ENV}"
                }
                
                // App credentials (required)
                withCredentials([
                    string(credentialsId: "${params.ENV.toUpperCase()}_APP_ORG_ID", variable: 'APP_ORG_ID'),
                    string(credentialsId: "${params.ENV.toUpperCase()}_APP_USERNAME", variable: 'APP_USERNAME'),
                    string(credentialsId: "${params.ENV.toUpperCase()}_APP_PASSWORD", variable: 'APP_PASSWORD')
                ]) {
                    script {
                        echo "Environment: ${params.ENV}"
                        echo "Browser: ${params.BROWSER}"
                        echo "Headless: ${params.HEADLESS}"
                        echo "Build Timestamp: ${TIMESTAMP}"
                    }
                    
                    bat 'npm ci'
                    bat 'npx playwright install --with-deps'
                }
            }
        }
        
        stage('Run Tests') {
            steps {
                withCredentials([
                    string(credentialsId: "${params.ENV.toUpperCase()}_APP_ORG_ID", variable: 'APP_ORG_ID'),
                    string(credentialsId: "${params.ENV.toUpperCase()}_APP_USERNAME", variable: 'APP_USERNAME'),
                    string(credentialsId: "${params.ENV.toUpperCase()}_APP_PASSWORD", variable: 'APP_PASSWORD')
                ]) {
                    script {
                        def testCommand = "npm run test:ci"
                        
                        // Add feature file filter
                        if (params.FEATURE_FILE?.trim()) {
                            testCommand = "npm run test:file ${params.FEATURE_FILE}"
                        }
                        
                        // Add tags filter
                        if (params.TAGS?.trim()) {
                            testCommand = "cucumber-js --config src/config/cucumber.js --tags \"${params.TAGS}\""
                        }
                        
                        // Both feature file and tags
                        if (params.FEATURE_FILE?.trim() && params.TAGS?.trim()) {
                            testCommand = "cucumber-js --config src/config/cucumber.js src/features/${params.FEATURE_FILE}*.feature --tags \"${params.TAGS}\""
                        }
                        
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            bat testCommand
                        }
                    }
                }
            }
        }
        
        stage('Generate Report') {
            steps {
                // Generate current report
                bat "npx allure-commandline generate reports/${params.ENV}/allure-results -o reports/${params.ENV}/allure-report --clean"
                
                // Copy to history with timestamp
                bat """
                    if not exist "reports\\${params.ENV}\\allure-report-history\\report-${TIMESTAMP}" mkdir "reports\\${params.ENV}\\allure-report-history\\report-${TIMESTAMP}"
                    xcopy /E /I /Y "reports\\${params.ENV}\\allure-report\\*" "reports\\${params.ENV}\\allure-report-history\\report-${TIMESTAMP}\\"
                """
                
                // Generate report index with Jenkins build info
                bat "node src/scripts/generate-report-index.js"
            }
        }
        
        stage('Archive Results') {
            steps {
                // Archive current report
                archiveArtifacts artifacts: "reports/${params.ENV}/allure-report/**/*", allowEmptyArchive: true
                archiveArtifacts artifacts: "reports/${params.ENV}/cucumber-report.json", allowEmptyArchive: true
                
                // Archive report index and history
                archiveArtifacts artifacts: "reports/${params.ENV}/report-index.html", allowEmptyArchive: true
                archiveArtifacts artifacts: "reports/${params.ENV}/build-history.json", allowEmptyArchive: true
            }
        }
        
        stage('Publish Allure Report') {
            steps {
                allure([
                    includeProperties: false,
                    jdk: '',
                    results: [[path: "reports/${params.ENV}/allure-results"]]
                ])
            }
        }
    }
    
    post {
        always {
            script {
                // Add link to report index in build description
                currentBuild.description = """
                    <a href='artifact/reports/${params.ENV}/report-index.html'>📊 Report History</a> | 
                    <a href='artifact/reports/${params.ENV}/allure-report/index.html'>📋 Latest Report</a>
                """
            }
        }
        
        failure {
            archiveArtifacts artifacts: "reports/${params.ENV}/runs/**/*", allowEmptyArchive: true
        }
    }
}
