pipeline {
    agent any
    
    parameters {
        choice(name: 'ENV', choices: ['qa', 'dev', 'stage', 'uat'], description: 'Target environment')
        choice(name: 'BROWSER', choices: ['chromium', 'firefox', 'webkit'], description: 'Browser to run tests')
        booleanParam(name: 'HEADLESS', defaultValue: true, description: 'Run in headless mode')
        string(name: 'PARALLEL', defaultValue: '0', description: 'Number of parallel workers (0 = sequential)')
        string(name: 'RETRY', defaultValue: '1', description: 'Number of retry attempts for failed tests')
        string(name: 'FEATURE_FILE', defaultValue: '', description: 'Specific feature file to run (leave empty for all)')
    }
    
    environment {
        ENV = "${params.ENV}"
        BROWSER = "${params.BROWSER}"
        HEADLESS = "${params.HEADLESS}"
        PARALLEL = "${params.PARALLEL}"
        RETRY = "${params.RETRY}"
        NODE_OPTIONS = '--max-old-space-size=4096'
    }
    
    options {
        timeout(time: 60, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '20', artifactNumToKeepStr: '10'))
        timestamps()
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Setup') {
            steps {
                withCredentials([
                    string(credentialsId: 'APP_ORG_ID', variable: 'APP_ORG_ID'),
                    string(credentialsId: 'APP_USERNAME', variable: 'APP_USERNAME'),
                    string(credentialsId: 'APP_PASSWORD', variable: 'APP_PASSWORD')
                ]) {
                    script {
                        echo "Environment: ${params.ENV}"
                        echo "Browser: ${params.BROWSER}"
                        echo "Headless: ${params.HEADLESS}"
                    }
                    
                    bat 'npm ci'
                    bat 'npx playwright install --with-deps'
                }
            }
        }
        
        stage('Run Tests') {
            steps {
                withCredentials([
                    string(credentialsId: 'APP_ORG_ID', variable: 'APP_ORG_ID'),
                    string(credentialsId: 'APP_USERNAME', variable: 'APP_USERNAME'),
                    string(credentialsId: 'APP_PASSWORD', variable: 'APP_PASSWORD')
                ]) {
                    script {
                        def testCommand = params.FEATURE_FILE?.trim() 
                            ? "npm run test:file ${params.FEATURE_FILE}"
                            : "npm run test:ci"
                        
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            bat testCommand
                        }
                    }
                }
            }
        }
        
        stage('Generate Report') {
            steps {
                bat "npx allure-commandline generate reports/${params.ENV}/allure-results -o reports/${params.ENV}/allure-report --clean"
            }
        }
        
        stage('Archive Results') {
            steps {
                archiveArtifacts artifacts: "reports/${params.ENV}/allure-results/**/*", allowEmptyArchive: true
                archiveArtifacts artifacts: "reports/${params.ENV}/allure-report/**/*", allowEmptyArchive: true
                archiveArtifacts artifacts: "reports/${params.ENV}/cucumber-report.json", allowEmptyArchive: true
            }
        }
        
        stage('Publish Allure Report') {
            steps {
                allure([
                    includeProperties: false,
                    jdk: '',
                    results: [[path: "reports/${params.ENV}/allure-results"]]
                ])
            }
        }
    }
    
    post {
        failure {
            archiveArtifacts artifacts: "reports/${params.ENV}/runs/**/*", allowEmptyArchive: true
        }
    }
}
