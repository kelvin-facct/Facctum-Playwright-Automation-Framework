{
  "name": "playwright-bdd",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "node -e \"const{execSync}=require('child_process');try{execSync('cucumber-js --config src/config/cucumber.js',{stdio:'inherit'})}catch(e){}execSync('npm run allure:report',{stdio:'inherit'})\"",
    "test:file": "node src/scripts/run-test.js",
    "test:ci": "cucumber-js --config src/config/cucumber.js",
    "test:fail-fast": "cucumber-js --config src/config/cucumber.js --fail-fast",
    "test:parallel": "cross-env PARALLEL=2 cucumber-js --config src/config/cucumber.js",
    "test:parallel:features": "node src/scripts/run-parallel-features.js",
    "test:parallel:features:report": "node src/scripts/run-parallel-features.js && npm run allure:report",
    "test:chrome": "cross-env BROWSER=chromium cucumber-js --config src/config/cucumber.js",
    "test:firefox": "cross-env BROWSER=firefox cucumber-js --config src/config/cucumber.js",
    "test:webkit": "cross-env BROWSER=webkit cucumber-js --config src/config/cucumber.js",
    "test:qa": "cross-env ENV=qa cucumber-js --config src/config/cucumber.js",
    "test:dev": "cross-env ENV=dev cucumber-js --config src/config/cucumber.js",
    "allure:generate": "node -e \"const e=process.env.ENV||'qa';require('child_process').execSync(`npx allure-commandline generate reports/${e}/allure-results --clean -o reports/${e}/allure-report`,{stdio:'inherit'})\"",
    "allure:archive": "node src/scripts/archive-report.js",
    "allure:open": "node -e \"const e=process.env.ENV||'qa';require('child_process').execSync(`npx allure-commandline open reports/${e}/allure-report`,{stdio:'inherit'})\"",
    "allure:report": "npm run allure:archive && npm run allure:generate && npm run allure:open",
    "test:report": "npm run test && npm run allure:report",
    "test:qa:report": "cross-env ENV=qa npm run test && cross-env ENV=qa npm run allure:report",
    "test:dev:report": "cross-env ENV=dev npm run test && cross-env ENV=dev npm run allure:report",
    "test:stage:report": "cross-env ENV=stage npm run test && cross-env ENV=stage npm run allure:report",
    "trace:show": "node src/scripts/show-trace.js",
    "report:html": "node src/scripts/generate-report.js",
    "report:open": "node src/scripts/generate-report.js && node -e \"const e=process.env.ENV||'qa';require('child_process').execSync(`start reports/${e}/test-report.html`,{shell:true})\"",
    "db:test": "npx ts-node src/scripts/test-dbQuery.ts",
    "db:test:full": "npx ts-node src/scripts/test-dbQuery.ts --full",
    "env:list": "npx ts-node src/scripts/list-envs.ts",
    "cleanup": "node src/scripts/cleanup-reports.js",
    "codegen": "npx playwright codegen"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.15.4",
    "allure-commandline": "^2.38.0",
    "allure-cucumberjs": "^3.6.0",
    "cross-env": "^10.1.0",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@aws-sdk/rds-signer": "^3.840.0",
    "@cucumber/cucumber": "^12.7.0",
    "pg": "^8.16.0",
    "playwright": "^1.58.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "winston": "^3.19.0"
  }
}
